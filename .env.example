# ============================================
# ProspectAI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys
# cp .env.example .env

# Geoapify Places API Key
# Get from: https://myprojects.geoapify.com/register
# Free tier: 3000 requests/day
GEOAPIFY_API_KEY=

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
# Free: 60 requests/min
GEMINI_API_KEY=

# Apollo.io API Key (Optional - Phase 2)
# Get from: https://app.apollo.io/#/settings/integrations/api
# Free: 10,000 records/month
APOLLO_API_KEY=

# Reddit API (Optional - Phase 2)
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ProspectAI/1.0

# App Settings
FLASK_PORT=5000
DEMO_MODE=true
DB_PATH=data/leads.db
